+int sys_clone(void *tcb, pid_t *pid_out, void *stack) {
+	if(!pid_out || !stack)
+		return EINVAL;
+
+	unsigned long flags = CLONE_VM | CLONE_FS | CLONE_FILES | CLONE_SIGHAND
+			| CLONE_THREAD | CLONE_SYSVSEM | CLONE_SETTLS
+			| CLONE_PARENT_SETTID;
+
+	auto ret = ::syscall(SYS_clone, flags, stack, pid_out, nullptr, tcb);
+	if(int e = sc_error(ret); e)
+		return e;
+
+	*pid_out = static_cast<pid_t>(ret);
+	return 0;
+}
+
+int sys_prepare_stack(
+	void **stack,
+	void *entry,
+	void *arg,
+	void *tcb,
+	size_t *stack_size,
+	size_t *guard_size,
+	void **stack_base
+) {
+	if(!stack || !stack_size || !guard_size || !stack_base)
+		return EINVAL;
+
+	constexpr size_t default_stack_size = 0x200000;
+	constexpr size_t stack_items = 3;
+	constexpr size_t minimum_stack_size = stack_items * sizeof(uintptr_t);
+
+	if(!*stack_size)
+		*stack_size = default_stack_size;
+	if(*stack_size < minimum_stack_size)
+		*stack_size = minimum_stack_size;
+
+	*guard_size = 0;
+
+	if(!*stack) {
+		int e = sys_anon_allocate(*stack_size, stack_base);
+		if(e)
+			return e;
+	} else {
+		*stack_base = *stack;
+	}
+
+	uintptr_t base = reinterpret_cast<uintptr_t>(*stack_base);
+	if(base > UINTPTR_MAX - *stack_size)
+		return EINVAL;
+
+	uintptr_t top = base + *stack_size;
+	top &= ~(sizeof(uintptr_t) - 1);
+
+	auto sp = reinterpret_cast<uintptr_t *>(top);
+	*--sp = reinterpret_cast<uintptr_t>(tcb);
+	*--sp = reinterpret_cast<uintptr_t>(arg);
+	*--sp = reinterpret_cast<uintptr_t>(entry);
+
+	*stack = reinterpret_cast<void *>(sp);
+	return 0;
+}
