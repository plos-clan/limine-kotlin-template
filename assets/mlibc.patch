+int sys_anon_allocate(size_t size, void **pointer) {
+	if (!pointer)
+		return EINVAL;
+
+	size = anon_align_up(size);
+	if (!size)
+		return ENOMEM;
+
+	void *result = nullptr;
+
+	anon_lock_acquire();
+
+	AnonBlock *previous = nullptr;
+	AnonBlock *current = anon_free_list;
+	while (current) {
+		if (current->size >= size) {
+			if (current->size - size >= anon_page_size) {
+				auto next =
+				    reinterpret_cast<AnonBlock *>(reinterpret_cast<uintptr_t>(current) + size);
+				next->size = current->size - size;
+				next->next = current->next;
+				if (previous)
+					previous->next = next;
+				else
+					anon_free_list = next;
+			} else {
+				size = current->size;
+				if (previous)
+					previous->next = current->next;
+				else
+					anon_free_list = current->next;
+			}
+
+			result = current;
+			break;
+		}
+
+		previous = current;
+		current = current->next;
+	}
+
+	if (!result) {
+		if (anon_bump > anon_arena_size - size) {
+			anon_lock_release();
+			return ENOMEM;
+		}
+
+		result = anon_arena + anon_bump;
+		anon_bump += size;
+	}
+
+	anon_lock_release();
+
+	memset(result, 0, size);
+	*pointer = result;
+	return 0;
+}
+
+int sys_anon_free(void *pointer, size_t size) {
+	if (!pointer)
+		return 0;
+
+	size = anon_align_up(size);
+	if (!size)
+		return EINVAL;
+
+	uintptr_t start = reinterpret_cast<uintptr_t>(anon_arena);
+	uintptr_t end = start + anon_arena_size;
+	uintptr_t address = reinterpret_cast<uintptr_t>(pointer);
+	if (address < start || address + size > end)
+		return EINVAL;
+
+	if (address & (anon_page_size - 1))
+		return EINVAL;
+
+	auto block = reinterpret_cast<AnonBlock *>(pointer);
+	block->size = size;
+	block->next = nullptr;
+
+	anon_lock_acquire();
+
+	AnonBlock *previous = nullptr;
+	AnonBlock *current = anon_free_list;
+	while (current && current < block) {
+		previous = current;
+		current = current->next;
+	}
+
+	block->next = current;
+	if (previous)
+		previous->next = block;
+	else
+		anon_free_list = block;
+
+	if (block->next
+	    && reinterpret_cast<uintptr_t>(block) + block->size
+	           == reinterpret_cast<uintptr_t>(block->next)) {
+		block->size += block->next->size;
+		block->next = block->next->next;
+	}
+
+	if (previous
+	    && reinterpret_cast<uintptr_t>(previous) + previous->size
+	           == reinterpret_cast<uintptr_t>(block)) {
+		previous->size += block->size;
+		previous->next = block->next;
+	}
+
+	anon_lock_release();
+	return 0;
+}
