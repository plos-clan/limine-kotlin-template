+int sys_vm_map(void *hint, size_t size, int prot, int flags, int fd, off_t offset, void **window) {
+	if (!window)
+		return EINVAL;
+	if (!size)
+		return EINVAL;
+	if (size >= PTRDIFF_MAX)
+		return ENOMEM;
+	if (offset < 0 || (offset & (anon_page_size - 1)))
+		return EINVAL;
+
+	int map_type = flags & (MAP_SHARED | MAP_PRIVATE);
+	if (map_type != MAP_SHARED && map_type != MAP_PRIVATE)
+		return EINVAL;
+
+#ifdef MAP_FIXED_NOREPLACE
+	bool fixed_noreplace = flags & MAP_FIXED_NOREPLACE;
+#else
+	bool fixed_noreplace = false;
+#endif
+	bool fixed = (flags & MAP_FIXED) || fixed_noreplace;
+	bool anonymous = flags & MAP_ANONYMOUS;
+
+	if (!anonymous) {
+		if (fd < 0)
+			return EBADF;
+		return ENOSYS;
+	}
+
+	(void)prot;
+	(void)fd;
+
+	size = anon_align_up(size);
+	if (!size)
+		return ENOMEM;
+
+	void *result = nullptr;
+	uintptr_t arena_base = reinterpret_cast<uintptr_t>(vm_arena);
+
+	vm_lock_acquire();
+
+	if (fixed) {
+		uintptr_t address = reinterpret_cast<uintptr_t>(hint);
+		if (address & (anon_page_size - 1)) {
+			vm_lock_release();
+			return EINVAL;
+		}
+		if (address < arena_base) {
+			vm_lock_release();
+			return ENOMEM;
+		}
+
+		size_t arena_offset = address - arena_base;
+		if (arena_offset > vm_arena_size - size) {
+			vm_lock_release();
+			return ENOMEM;
+		}
+
+		if (fixed_noreplace && arena_offset < vm_bump) {
+			vm_lock_release();
+			return EEXIST;
+		}
+
+		size_t map_end = arena_offset + size;
+		if (map_end > vm_bump)
+			vm_bump = map_end;
+		result = reinterpret_cast<void *>(address);
+	} else {
+		if (vm_bump > vm_arena_size - size) {
+			vm_lock_release();
+			return ENOMEM;
+		}
+
+		result = vm_arena + vm_bump;
+		vm_bump += size;
+	}
+
+	vm_lock_release();
+
+	memset(result, 0, size);
+	*window = result;
+	return 0;
+}
