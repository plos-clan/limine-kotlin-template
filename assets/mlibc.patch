+namespace {
+
+constexpr size_t anon_page_size = 0x1000;
+constexpr size_t anon_arena_size = 16 * 1024 * 1024;
+constexpr size_t vm_arena_size = 64 * 1024 * 1024;
+
+struct AnonBlock {
+	size_t size;
+	AnonBlock *next;
+};
+
+alignas(anon_page_size) static unsigned char anon_arena[anon_arena_size];
+alignas(anon_page_size) static unsigned char vm_arena[vm_arena_size];
+static size_t anon_bump = 0;
+static size_t vm_bump = 0;
+static AnonBlock *anon_free_list = nullptr;
+static int anon_lock = 0;
+static int vm_lock = 0;
+
+static inline size_t anon_align_up(size_t n) {
+	if (n > SIZE_MAX - (anon_page_size - 1))
+		return 0;
+	return (n + anon_page_size - 1) & ~(anon_page_size - 1);
+}
+
+static inline void anon_lock_acquire() {
+	while (__atomic_test_and_set(&anon_lock, __ATOMIC_ACQUIRE))
+		cpu_relax();
+}
+
+static inline void anon_lock_release() { __atomic_clear(&anon_lock, __ATOMIC_RELEASE); }
+
+static inline void vm_lock_acquire() {
+	while (__atomic_test_and_set(&vm_lock, __ATOMIC_ACQUIRE))
+		cpu_relax();
+}
+
+static inline void vm_lock_release() { __atomic_clear(&vm_lock, __ATOMIC_RELEASE); }
+
+} // namespace
