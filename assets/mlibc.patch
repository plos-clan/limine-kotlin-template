+int sys_futex_wait(int *pointer, int expected, const struct timespec *time) {
+	// Fake futex for early bring-up: spin until the futex word changes.
+	if (__atomic_load_n(pointer, __ATOMIC_ACQUIRE) != expected)
+		return EAGAIN;
+
+	unsigned long long spin_budget = 0;
+	if (time) {
+		if (time->tv_nsec < 0 || time->tv_nsec >= 1'000'000'000)
+			return EINVAL;
+		if (time->tv_sec == 0 && time->tv_nsec == 0)
+			return ETIMEDOUT;
+
+		unsigned long long timeout_ns = 0;
+		if ((unsigned long long)time->tv_sec > ULLONG_MAX / 1'000'000'000)
+			timeout_ns = ULLONG_MAX;
+		else
+			timeout_ns = (unsigned long long)time->tv_sec * 1'000'000'000;
+		if (timeout_ns != ULLONG_MAX) {
+			unsigned long long rem = ULLONG_MAX - timeout_ns;
+			if ((unsigned long long)time->tv_nsec > rem)
+				timeout_ns = ULLONG_MAX;
+			else
+				timeout_ns += (unsigned long long)time->tv_nsec;
+		}
+
+		constexpr unsigned long long ns_per_spin = 64;
+		spin_budget = timeout_ns / ns_per_spin;
+		if (spin_budget != ULLONG_MAX)
+			++spin_budget;
+	}
+
+	while (__atomic_load_n(pointer, __ATOMIC_ACQUIRE) == expected) {
+		cpu_relax();
+		if (time) {
+			if (!spin_budget)
+				return ETIMEDOUT;
+			--spin_budget;
+		}
+	}
+
+	return 0;
+}
