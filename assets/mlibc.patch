+int sys_ppoll(
+	struct pollfd *fds,
+	int nfds,
+	const struct timespec *timeout,
+	const sigset_t *sigmask,
+	int *num_events
+) {
+	if(!num_events)
+		return EINVAL;
+
+	auto ret = ::syscall(SYS_ppoll, fds, nfds, timeout, sigmask, NSIG / 8);
+	if(int e = sc_error(ret); e)
+		return e;
+	*num_events = static_cast<int>(ret);
+	return 0;
+}
+
+int sys_poll(struct pollfd *fds, nfds_t count, int timeout, int *num_events) {
+	struct timespec ts = {};
+	struct timespec *pts = nullptr;
+	if(timeout >= 0) {
+		ts.tv_sec = timeout / 1000;
+		ts.tv_nsec = (timeout % 1000) * 1000000;
+		pts = &ts;
+	}
+	return sys_ppoll(fds, static_cast<int>(count), pts, nullptr, num_events);
+}
+
+int sys_pselect(
+	int nfds,
+	fd_set *read_set,
+	fd_set *write_set,
+	fd_set *except_set,
+	const struct timespec *timeout,
+	const sigset_t *sigmask,
+	int *num_events
+) {
+	if(!num_events)
+		return EINVAL;
+
+	struct timespec local_timeout = {};
+	if(timeout)
+		local_timeout = *timeout;
+
+	struct {
+		const sigset_t *sigmask;
+		size_t ss_len;
+	} data = {sigmask, NSIG / 8};
+
+	auto ret = ::syscall(
+		SYS_pselect6,
+		nfds,
+		read_set,
+		write_set,
+		except_set,
+		timeout ? &local_timeout : nullptr,
+		&data
+	);
+	if(int e = sc_error(ret); e)
+		return e;
+	*num_events = static_cast<int>(ret);
+	return 0;
+}
