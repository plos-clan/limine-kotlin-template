+int sys_ttyname(int fd, char *buf, size_t size) {
+	if(!buf || !size)
+		return EINVAL;
+
+	if(int e = sys_isatty(fd); e)
+		return e;
+
+	char link_path[64];
+	int n = snprintf(link_path, sizeof(link_path), "/proc/self/fd/%d", fd);
+	if(n < 0 || static_cast<size_t>(n) >= sizeof(link_path))
+		return ENAMETOOLONG;
+
+	ssize_t length = 0;
+	if(int e = sys_readlink(link_path, buf, size, &length); e)
+		return e;
+	if(length < 0 || static_cast<size_t>(length) >= size)
+		return ERANGE;
+	buf[length] = '\0';
+
+	struct stat path_stat = {};
+	struct stat fd_stat = {};
+	if(int e = sys_stat(fsfd_target::path, -1, buf, 0, &path_stat); e)
+		return e;
+	if(int e = sys_stat(fsfd_target::fd, fd, "", 0, &fd_stat); e)
+		return e;
+
+	if(path_stat.st_dev != fd_stat.st_dev || path_stat.st_ino != fd_stat.st_ino)
+		return ENODEV;
+
+	return 0;
+}
