+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_setsockopt(int fd, int layer, int number, const void *buffer, socklen_t size) {
+	auto ret = ::syscall(SYS_setsockopt, fd, layer, number, buffer, size, 0);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_msg_recv(int sockfd, struct msghdr *hdr, int flags, ssize_t *length) {
+	if(!length)
+		return EINVAL;
+	auto ret = ::syscall(SYS_recvmsg, sockfd, hdr, flags);
+	if(int e = sc_error(ret); e)
+		return e;
+	*length = static_cast<ssize_t>(ret);
+	return 0;
+}
+
+int sys_peername(
+	int fd, struct sockaddr *addr_ptr, socklen_t max_addr_length, socklen_t *actual_length
+) {
+	if(!actual_length)
+		return EINVAL;
+	auto ret = ::syscall(SYS_getpeername, fd, addr_ptr, &max_addr_length);
+	if(int e = sc_error(ret); e)
+		return e;
+	*actual_length = max_addr_length;
+	return 0;
+}
+
+int sys_listen(int fd, int backlog) {
+	auto ret = ::syscall(SYS_listen, fd, backlog);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_inotify_create(int flags, int *fd) {
+	if(!fd)
+		return EINVAL;
+	auto ret = ::syscall(SYS_inotify_init1, flags);
+	if(int e = sc_error(ret); e)
+		return e;
+	*fd = static_cast<int>(ret);
+	return 0;
+}
+
+int sys_fork(pid_t *child) {
+	if(!child)
+		return EINVAL;
+#if defined(SYS_clone)
+	auto ret = ::syscall(SYS_clone, SIGCHLD, 0);
+#else
+	auto ret = ::syscall(SYS_fork);
+#endif
+	if(int e = sc_error(ret); e)
+		return e;
+	*child = static_cast<pid_t>(ret);
+	return 0;
+}
+
+int sys_execve(const char *path, char *const argv[], char *const envp[]) {
+	auto ret = ::syscall(SYS_execve, path, argv, envp);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_fcntl(int fd, int request, va_list args, int *result) {
+	auto arg = va_arg(args, unsigned long);
+	auto ret = ::syscall(SYS_fcntl, fd, request, arg);
+	if(int e = sc_error(ret); e)
+		return e;
+	if(result)
+		*result = static_cast<int>(ret);
+	return 0;
+}
+
+int sys_dup(int fd, int flags, int *newfd) {
+	if(!newfd)
+		return EINVAL;
+	if(flags)
+		return EINVAL;
+	auto ret = ::syscall(SYS_dup, fd);
+	if(int e = sc_error(ret); e)
+		return e;
+	*newfd = static_cast<int>(ret);
+	return 0;
+}
+
+int sys_dup2(int fd, int flags, int newfd) {
+#if defined(SYS_dup3)
+	auto ret = ::syscall(SYS_dup3, fd, newfd, flags);
+#else
+	if(flags)
+		return EINVAL;
+	auto ret = ::syscall(SYS_dup2, fd, newfd);
+#endif
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int
+sys_sigprocmask(int how, const sigset_t *__restrict set, sigset_t *__restrict retrieve) {
+	auto ret = ::syscall(SYS_rt_sigprocmask, how, set, retrieve, NSIG / 8);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_sigaction(int signum, const struct sigaction *act, struct sigaction *oldact) {
+	auto ret = ::syscall(SYS_rt_sigaction, signum, act, oldact, NSIG / 8);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_signalfd_create(const sigset_t *masks, int flags, int *fd) {
+	if(!fd)
+		return EINVAL;
+	auto ret = ::syscall(SYS_signalfd4, *fd, masks, NSIG / 8, flags);
+	if(int e = sc_error(ret); e)
+		return e;
+	*fd = static_cast<int>(ret);
+	return 0;
+}
+
+int sys_waitpid(pid_t pid, int *status, int flags, struct rusage *ru, pid_t *ret_pid) {
+	if(!ret_pid)
+		return EINVAL;
+	auto ret = ::syscall(SYS_wait4, pid, status, flags, ru);
+	if(int e = sc_error(ret); e)
+		return e;
+	*ret_pid = static_cast<pid_t>(ret);
+	return 0;
+}
+
+int sys_getgroups(size_t size, gid_t *list, int *_ret) {
+	if(!_ret)
+		return EINVAL;
+	auto ret = ::syscall(SYS_getgroups, size, list);
+	if(int e = sc_error(ret); e)
+		return e;
+	*_ret = static_cast<int>(ret);
+	return 0;
+}
+
+int sys_mount(
+	const char *source,
+	const char *target,
+	const char *fstype,
+	unsigned long flags,
+	const void *data
+) {
+	auto ret = ::syscall(SYS_mount, source, target, fstype, flags, data);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_umount2(const char *target, int flags) {
+	auto ret = ::syscall(SYS_umount2, target, flags);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_gethostname(char *buffer, size_t bufsize) {
+	if(!buffer || !bufsize)
+		return EINVAL;
+
+	struct utsname name = {};
+	auto ret = ::syscall(SYS_uname, &name);
+	if(int e = sc_error(ret); e)
+		return e;
+
+	auto len = strlen(name.nodename);
+	if(len >= bufsize)
+		return ENAMETOOLONG;
+	memcpy(buffer, name.nodename, len + 1);
+	return 0;
+}
+
+int sys_sethostname(const char *buffer, size_t bufsize) {
+	auto ret = ::syscall(SYS_sethostname, buffer, bufsize);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_sleep(time_t *secs, long *nanos) {
+	if(!secs || !nanos)
+		return EINVAL;
+	if(*nanos < 0 || *nanos >= 1'000'000'000)
+		return EINVAL;
+
+	struct timespec req = {
+		.tv_sec = *secs,
+		.tv_nsec = *nanos
+	};
+	struct timespec rem = {};
+	auto ret = ::syscall(SYS_nanosleep, &req, &rem);
+	if(int e = sc_error(ret); e)
+		return e;
+
+	*secs = rem.tv_sec;
+	*nanos = rem.tv_nsec;
+	return 0;
+}
+
+int sys_getitimer(int which, struct itimerval *curr_value) {
+	auto ret = ::syscall(SYS_getitimer, which, curr_value);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
+
+int sys_setitimer(int which, const struct itimerval *new_value, struct itimerval *old_value) {
+	auto ret = ::syscall(SYS_setitimer, which, new_value, old_value);
+	if(int e = sc_error(ret); e)
+		return e;
+	return 0;
+}
